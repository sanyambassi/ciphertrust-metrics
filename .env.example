# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5050
FLASK_DEBUG=true
# HTTPS with auto-generated self-signed cert (data/certs/) on first start
FLASK_HTTPS=true
# Also listen on plain HTTP (no redirect to HTTPS). Useful behind a proxy or for IP access.
# FLASK_HTTP=true
# FLASK_HTTP_PORT=80
# Optional SANs for the self-signed cert (comma-separated IPs and/or DNS names)
# SSL_EXTRA_SANS=192.0.2.10,metrics.example.com
# SSL_CERT_PATH=data/certs/cert.pem
# SSL_KEY_PATH=data/certs/key.pem

# SQLite path (default: data/cm_metrics.db)
# DATABASE_PATH=data/cm_metrics.db

SCRAPE_INTERVAL=15
HISTORY_SECONDS=86400
HISTORY_KEEP_DAYS=7

# Seed a demo appliance if none exist / live scrape fails
DEMO_MODE=false

# Used to encrypt stored CM passwords (auto-generated if omitted)
# SECRET_KEY=change-me
